# ─────────────────────────────────────────────────────────────
# GDG on Campus HAU Photobooth — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file and rename it to .env, then fill in your values.
# NEVER commit your actual .env file to version control.
#
# For local development:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values in .env
#
# For Vercel deployment:
#   Add these variables in your Vercel project's Settings > Environment Variables
# ─────────────────────────────────────────────────────────────

# Nodemailer — Gmail SMTP (used by api/sendEmail.js)
# The Gmail address that sends the photo strip to attendees
GMAIL_USER=your_gmail_address@gmail.com

# Gmail App Password (NOT your normal password)
# Steps to generate one:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create a new App Password (name it e.g. "Vercel Photobooth")
#   4. Paste the 16-character code here (no spaces)
GMAIL_APP_PASSWORD=your_16_character_app_password
